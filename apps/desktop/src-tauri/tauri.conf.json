{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Aiotto",
  "version": "0.1.2",
  "identifier": "app.aiotto.desktop",
  "build": {
    "frontendDist": "../../../dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "cd ../.. && pnpm run dev --host 127.0.0.1 --port 5173 --strictPort",
    "beforeBuildCommand": "cd ../.. && pnpm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "",
        "width": 1200,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": true,
        "acceptFirstMouse": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "publisher": "ShawnZhuge",
    "copyright": "© 2026 ShawnZhuge",
    "targets": [
      "app",
      "dmg"
    ],
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "hardenedRuntime": true,
      "dmg": {
        "windowSize": {
          "width": 660,
          "height": 400
        },
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        }
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY3RkU3RjUzRDMzREU4MUQKUldRZDZEM1RVMy8rOXhSRWRBbHJnT1dNR0w1S3MxdjVSV0VVaHJxSXVXSVJBVFhiN0hoTGZVYmMK",
      "endpoints": [
        "https://github.com/ShawnZhuge/aiotto/releases/latest/download/latest.json"
      ]
    }
  }
}
